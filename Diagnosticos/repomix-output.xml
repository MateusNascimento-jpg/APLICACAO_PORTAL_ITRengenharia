  .campo-caixa i.ti{ flex:0 0 auto; padding-left:13px; color:var(--txt-4); font-size:17px; }
  .campo-caixa input{
    flex:1; min-width:0; background:transparent; border:0; outline:0;
    color:var(--txt); font-family:inherit; font-size:14.5px;
    padding:12px 12px 12px 9px;
  }
  .campo-caixa input::placeholder{ color:var(--txt-4); }
  .campo-caixa.com-acao input{ padding-right:6px; }
  .btn-olho{
    flex:0 0 auto; background:transparent; border:0; cursor:pointer;
    color:var(--txt-4); padding:8px 12px; display:flex; align-items:center;
    transition:color .2s;
  }
  .btn-olho:hover{ color:var(--azul-claro); }
  .btn-olho svg{ width:18px; height:18px; }

  .campo-erro{
    display:none; align-items:center; gap:6px; font-size:12px; color:var(--erro-tx);
    margin-top:-2px;
  }
  .campo-erro.ver{ display:flex; }
  .campo-erro svg{ width:13px; height:13px; flex:0 0 auto; }
  .campo-grupo.invalido .campo-caixa{ border-color:rgba(220,90,90,0.55); }

  .linha-aux{ display:flex; align-items:center; justify-content:space-between; font-size:12.5px; margin-top:-.3rem; }
  .lembrar{ display:flex; align-items:center; gap:7px; color:var(--txt-3); cursor:pointer; user-select:none; }
  .lembrar input{ accent-color:var(--azul); width:14px; height:14px; cursor:pointer; }
  .link-esqueci{ color:var(--azul-link); text-decoration:none; }
  .link-esqueci:hover{ text-decoration:underline; }

  .alerta-form{
    display:none; align-items:flex-start; gap:9px;
    background:var(--erro-bg); border:1px solid var(--erro-bd); color:var(--erro-tx);
    border-radius:11px; padding:11px 13px; font-size:13px; line-height:1.45;
  }
  .alerta-form.ver{ display:flex; }
  .alerta-form svg{ width:16px; height:16px; flex:0 0 auto; margin-top:1px; }

  .btn-entrar{
    display:flex; align-items:center; justify-content:center; gap:9px;
    background:var(--azul); color:#fff; border:0; border-radius:11px;
    padding:13px; font-size:14.5px; font-weight:600; font-family:inherit; cursor:pointer;
    transition:background .2s, transform .15s, box-shadow .2s;
    box-shadow:0 10px 24px -10px rgba(61,123,224,.6);
    margin-top:.2rem;
  }
  .btn-entrar:hover{ background:#3672cf; transform:translateY(-1px); }
  .btn-entrar:active{ transform:translateY(0); }
  .btn-entrar:disabled{ opacity:.65; cursor:default; transform:none; }
  .btn-entrar svg{ width:18px; height:18px; }
  .btn-entrar .ti-loader-2 svg{ animation:girar 0.85s linear infinite; }
  @keyframes girar{ to{ transform:rotate(360deg); } }

  .form-rodape{ text-align:center; font-size:13px; color:var(--txt-3); margin-top:1.5rem; }
  .form-rodape a{ color:var(--azul-link); text-decoration:none; font-weight:600; }
  .form-rodape a:hover{ text-decoration:underline; }

  .rodape-pagina{
    position:relative; z-index:3; text-align:center; color:var(--txt-4);
    font-size:11.5px; padding-bottom:1.6rem;
  }

  /* ===== Responsivo: empilha em telas estreitas (mobile) ===== */
  @media (max-width: 760px){
    .topo .logo-link img{ width:124px; }
    .moldura{ grid-template-columns:1fr; max-width:440px; }
    .vitrine{ display:none; }
    .form-painel{ padding:2.1rem 1.6rem; }
    .palco{ padding:1.6rem 1.1rem 2.2rem; }
  }

  /* Acessibilidade: respeita prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce){
    *{ animation-duration:0.001ms !important; transition-duration:0.001ms !important; }
  }
  :focus-visible{ outline:2px solid var(--azul-claro); outline-offset:2px; }

  /* ===== PAINEL DO DIRETOR — específico ===== */
  .painel-wrap{ position:relative; z-index:3; max-width:1120px; margin:0 auto; width:100%; padding:1.6rem 1.4rem 4rem; }

  .painel-cabeca{ display:flex; align-items:flex-end; justify-content:space-between; gap:1rem; margin-bottom:1.6rem; flex-wrap:wrap; }

  /* Título com bloco azul de destaque atrás */
  .titulo-bloco{ position:relative; display:inline-block; }
  .titulo-bloco h1{
    position:relative; z-index:1; font-size:30px; font-weight:700; letter-spacing:-.3px;
    color:var(--txt); padding:2px 14px;
  }
  .titulo-bloco::before{
    content:''; position:absolute; z-index:0; left:-4px; bottom:-2px;
    width:calc(100% + 8px); height:64%;
    background:linear-gradient(120deg, rgba(41,74,140,.95), rgba(61,123,224,.55));
    border-radius:8px; transform:rotate(-.6deg);
  }
  .painel-cabeca p{ font-size:13.5px; color:var(--txt-3); margin-top:8px; padding-left:2px; }

  /* Busca de cliente */
  .busca-caixa{ position:relative; display:flex; align-items:center; background:var(--field); border:0.5px solid var(--line-soft); border-radius:12px; min-width:260px; }
  .busca-caixa:focus-within{ border-color:rgba(123,162,230,0.65); box-shadow:0 0 0 3px rgba(61,123,224,0.16); }
  .busca-caixa i.ti{ padding-left:13px; color:var(--txt-4); font-size:16px; }
  .busca-caixa input{ flex:1; min-width:0; background:transparent; border:0; outline:0; color:var(--txt); font-family:inherit; font-size:14px; padding:11px 13px 11px 9px; }
  .busca-caixa input::placeholder{ color:var(--txt-4); }

  /* Nuvenzinhas de clientes — MAIORES */
  .nuvens{ display:flex; flex-wrap:wrap; gap:14px; }
  .nuvem{
    display:inline-flex; align-items:center; gap:13px;
    background:var(--card-2); border:0.5px solid var(--line-soft);
    border-radius:16px; padding:16px 22px 16px 17px; cursor:pointer;
    font-family:inherit; font-size:15.5px; color:var(--txt); font-weight:600;
    transition:border-color .18s, transform .15s, background .18s, box-shadow .2s;
  }
  .nuvem:hover{ border-color:rgba(123,162,230,0.6); transform:translateY(-3px); background:var(--card); box-shadow:0 14px 30px -18px rgba(0,0,0,.5); }
  .nuvem .nuvem-ico{ width:40px; height:40px; border-radius:12px; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg, rgba(61,123,224,.25), rgba(61,123,224,.10)); color:var(--azul-claro); flex:0 0 auto; }
  .nuvem .nuvem-ico svg{ width:20px; height:20px; }

  .estado-vazio{ text-align:center; color:var(--txt-4); font-size:14px; padding:3rem 1rem; width:100%; }
  .estado-vazio svg{ width:36px; height:36px; opacity:.5; margin-bottom:.7rem; }

  /* Voltar */
  .btn-voltar{ display:inline-flex; align-items:center; gap:7px; background:transparent; border:0; color:var(--azul-link); font-family:inherit; font-size:13.5px; cursor:pointer; padding:6px 2px; margin-bottom:.5rem; }
  .btn-voltar svg{ width:16px; height:16px; }
  .btn-voltar:hover{ text-decoration:underline; }

  /* Barra de filtros (dentro do cliente) */
  .filtros-barra{ display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin:.2rem 0 1.2rem; }
  .filtros-chips{ display:flex; gap:8px; flex-wrap:wrap; }
  .chip-filtro{
    display:inline-flex; align-items:center; gap:7px;
    background:var(--field); border:0.5px solid var(--line-soft); border-radius:999px;
    padding:8px 15px; font-family:inherit; font-size:13px; font-weight:600; color:var(--txt-3);
    cursor:pointer; transition:border-color .18s, color .18s, background .18s;
  }
  .chip-filtro:hover{ color:var(--txt); border-color:var(--line); }
  .chip-filtro.ativo{ background:rgba(61,123,224,.16); border-color:rgba(61,123,224,.5); color:var(--azul-claro); }
  .chip-filtro .cont{ font-size:11px; background:rgba(120,140,170,.2); border-radius:999px; padding:1px 7px; }
  .chip-filtro.ativo .cont{ background:rgba(61,123,224,.28); }

  /* Lista compacta de trabalhos */
  .trabalhos-lista{ display:flex; flex-direction:column; gap:9px; }
  .card-trab{
    background:var(--card); border:0.5px solid var(--line-soft); border-radius:12px;
    padding:12px 15px; display:flex; align-items:center; gap:14px;
    transition:border-color .18s, background .18s;
  }
  .card-trab:hover{ border-color:var(--line); }

  /* Ícone PDF verde pequeno e uniforme */
  .pdf-mini{
    flex:0 0 auto; width:38px; height:44px; position:relative;
    display:flex; align-items:center; justify-content:center;
  }
  .pdf-mini svg{ width:38px; height:44px; }
  .pdf-mini .pdf-tag{
    position:absolute; bottom:7px; left:50%; transform:translateX(-50%);
    font-size:7.5px; font-weight:800; letter-spacing:.5px; color:#fff;
  }

  .card-trab-info{ flex:1; min-width:0; }
  .card-trab-titulo{ font-size:14.5px; font-weight:600; color:var(--txt); display:flex; align-items:center; gap:9px; flex-wrap:wrap; line-height:1.3; }
  .card-trab-amostra{ font-size:12.5px; color:var(--txt-2); margin-top:3px; }
  .card-trab-amostra b{ color:var(--txt); font-weight:600; }
  .card-trab-id{ font-size:11px; color:var(--txt-4); margin-top:2px; font-family:'Consolas','Monaco',monospace; }

  .selo{ font-size:10.5px; font-weight:700; border-radius:999px; padding:3px 10px; letter-spacing:.2px; white-space:nowrap; }
  .selo-verde{ background:var(--verde-bg); border:1px solid var(--verde-bd); color:var(--verde-tx); }
  .selo-amarelo{ background:var(--amarelo-bg); border:1px solid var(--amarelo-bd); color:var(--amarelo-tx); }
  .selo-cinza{ background:var(--cinza-bg); color:var(--cinza-tx); }

  /* Ações */
  .card-trab-acoes{ display:flex; align-items:center; gap:7px; flex-wrap:wrap; flex:0 0 auto; }
  .btn-acao{
    display:inline-flex; align-items:center; gap:5px;
    border-radius:8px; padding:7px 11px; font-size:12.5px; font-weight:600;
    font-family:inherit; cursor:pointer; border:1px solid transparent;
    transition:transform .12s, filter .15s, background .15s, border-color .15s;
  }
  .btn-acao svg{ width:14px; height:14px; }
  .btn-acao:hover{ transform:translateY(-1px); }
  .btn-acao:disabled{ opacity:.55; cursor:default; transform:none; }
  .btn-aprovar{ background:var(--azul); color:#fff; box-shadow:0 7px 16px -9px rgba(61,123,224,.6); }
  .btn-aprovar:hover{ filter:brightness(1.06); }
  .btn-refazer{ background:transparent; color:var(--amarelo-tx); border-color:var(--amarelo-bd); }
  .btn-refazer:hover{ background:var(--amarelo-bg); }
  .btn-andamento{ background:transparent; color:var(--txt-3); border-color:var(--line-soft); }
  .btn-andamento:hover{ background:var(--cinza-bg); color:var(--txt-2); }

  .card-trab.processando{ opacity:.6; pointer-events:none; }
  .aviso-sem-rel{ display:inline-flex; align-items:center; gap:6px; font-size:12px; color:var(--txt-4); font-style:italic; }
  .aviso-sem-rel svg{ width:14px; height:14px; }

  /* Toast */
  .toast{
    position:fixed; left:50%; bottom:26px; transform:translateX(-50%) translateY(20px);
    z-index:50; display:flex; align-items:center; gap:9px;
    background:var(--card-2); border:0.5px solid var(--line); color:var(--txt);
    border-radius:12px; padding:12px 18px; font-size:13.5px;
    box-shadow:0 18px 40px -18px rgba(0,0,0,.6); opacity:0; pointer-events:none;
    transition:opacity .25s, transform .25s;
  }
  .toast.ver{ opacity:1; transform:translateX(-50%) translateY(0); }
  .toast svg{ width:17px; height:17px; flex:0 0 auto; }
  .toast.ok svg{ color:var(--verde-tx); }
  .toast.erro svg{ color:var(--erro-tx); }

  .carregando-linha{ display:flex; align-items:center; gap:10px; color:var(--txt-3); font-size:13.5px; padding:1.6rem .2rem; }
  .carregando-linha .ti-loader-2 svg{ animation:girar .85s linear infinite; }

  @media (max-width: 720px){
    .titulo-bloco h1{ font-size:24px; }
    .card-trab{ flex-wrap:wrap; }
    .card-trab-acoes{ width:100%; }
    .nuvem{ width:100%; }
  }

</style>
</head>
<body>

<canvas id="campo" aria-hidden="true"></canvas>
<div id="vinheta" aria-hidden="true"></div>

<header class="topo">
  <a href="#" class="logo-link" id="logoLink" aria-label="ITR Engenharia">
    <img src="data:image/png;base64," alt="ITR Engenharia">
  </a>
  <div style="display:flex; align-items:center; gap:10px;">
    <button class="btn-tema" id="btnTema" type="button" aria-label="Alternar tema claro/escuro" title="Alternar tema">
      <span id="iconeTema"></span>
    </button>
    <button class="btn-tema" id="btnSair" type="button" aria-label="Sair" title="Sair" style="width:auto; padding:0 13px; gap:7px; font-size:13px; font-weight:600;">
      <i class="ti ti-logout"></i> Sair
    </button>
  </div>
</header>

<main class="painel-wrap">

  <!-- Toast -->
  <div class="toast" id="toast"><span class="toast-ico"></span><span class="toast-txt"></span></div>

  <!-- TELA 1: nuvenzinhas de clientes -->
  <div id="telaClientes">
    <div class="painel-cabeca">
      <div>
        <div class="titulo-bloco"><h1>Clientes</h1></div>
        <p>Selecione um cliente para ver os relatórios e aprovar.</p>
      </div>
      <div class="busca-caixa">
        <i class="ti ti-search"></i>
        <input type="text" id="buscaCliente" placeholder="Buscar cliente..." autocomplete="off">
      </div>
    </div>
    <div class="nuvens" id="nuvens"></div>
  </div>

  <!-- TELA 2: trabalhos do cliente selecionado -->
  <div id="telaTrabalhos" style="display:none;">
    <button class="btn-voltar" id="btnVoltar"><i class="ti ti-arrow-left"></i> Todos os clientes</button>
    <div class="painel-cabeca">
      <div>
        <div class="titulo-bloco"><h1 id="tituloCliente">Cliente</h1></div>
        <p>Relatórios dos últimos 6 meses. Aprove, peça refação ou marque em andamento.</p>
      </div>
      <div class="busca-caixa">
        <i class="ti ti-search"></i>
        <input type="text" id="buscaTrab" placeholder="Buscar amostra ou ensaio..." autocomplete="off">
      </div>
    </div>
    <div class="filtros-barra">
      <div class="filtros-chips" id="chipsFiltro"></div>
    </div>
    <div class="trabalhos-lista" id="trabalhosLista"></div>
  </div>

</main>



<script>
/* =========================================================================
   PAINEL DO DIRETOR — ITR Engenharia
   Estilo B. Consome: GET /api/clientes, GET /api/cliente/:id/trabalhos,
   PATCH /api/trabalho/:id/aprovacao. Todas exigem token de Diretor.
   ========================================================================= */

var TI_SVG = {
  'check':'<path d="M5 12l5 5l10 -10"/>',
  'clock':'<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>',
  'building':'<path d="M3 21l18 0"/><path d="M9 8l1 0"/><path d="M9 12l1 0"/><path d="M9 16l1 0"/><path d="M14 8l1 0"/><path d="M14 12l1 0"/><path d="M14 16l1 0"/><path d="M5 21v-16a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v16"/>',
  'search':'<path d="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0 -14 0"/><path d="M21 21l-6 -6"/>',
  'arrow-left':'<path d="M5 12l14 0"/><path d="M5 12l6 6"/><path d="M5 12l6 -6"/>',
  'file':'<path d="M14 3v4a1 1 0 0 0 1 1h4"/><path d="M17 21h-10a2 2 0 0 1 -2 -2v-14a2 2 0 0 1 2 -2h7l5 5v11a2 2 0 0 1 -2 2z"/>',
  'refresh':'<path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/><path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/>',
  'progress':'<path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9l6 6"/>',
  'alert-circle':'<circle cx="12" cy="12" r="9"/><path d="M12 8v4"/><path d="M12 16l.01 0"/>',
  'loader-2':'<path d="M12 3a9 9 0 1 0 9 9"/>',
  'inbox':'<path d="M4 13h3l3 3h4l3 -3h3"/><path d="M4 13v4a2 2 0 0 0 2 2h12a2 2 0 0 0 2 -2v-4l-3.45 -6.9a2 2 0 0 0 -1.8 -1.1h-9.5a2 2 0 0 0 -1.8 1.1z"/>',
  'sol':'<circle cx="12" cy="12" r="4"/><path d="M3 12h1M20 12h1M12 3v1M12 20v1M5.6 5.6l.7 .7M17.7 17.7l.7 .7M18.4 5.6l-.7 .7M6.3 17.7l-.7 .7"/>',
  'lua':'<path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"/>',
  'logout':'<path d="M14 8v-2a2 2 0 0 0 -2 -2h-7a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2 -2v-2"/><path d="M9 12h12l-3 -3"/><path d="M18 15l3 -3"/>'
};
function svgIcone(nome){
  var corpo = TI_SVG[nome];
  if(!corpo) return '';
  return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">'+corpo+'</svg>';
}
function aplicarIcones(raiz){
  (raiz||document).querySelectorAll('i.ti').forEach(function(el){
    if(el.getAttribute('data-svg-ok')) return;
    var nome = '';
    el.classList.forEach(function(c){ if(c.indexOf('ti-')===0) nome=c.slice(3); });
    var svg = svgIcone(nome);
    if(svg){ el.innerHTML = svg; el.setAttribute('data-svg-ok','1'); }
  });
}

/* ---- Fundo blueprint ---- */
(function(){
  var cv = document.getElementById('campo');
  var ctx = cv.getContext('2d');
  var passo = 40;
  function desenhar(){
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var W = window.innerWidth, H = Math.max(window.innerHeight, document.body.scrollHeight);
    cv.width = W*dpr; cv.height = H*dpr; cv.style.width=W+'px'; cv.style.height=H+'px';
    ctx.setTransform(dpr,0,0,dpr,0,0);
    ctx.clearRect(0,0,W,H);
    var cs = getComputedStyle(document.documentElement);
    var forte = (cs.getPropertyValue('--grade-forte')||'rgba(120,140,165,0.13)').trim();
    var fraca = (cs.getPropertyValue('--grade-fraca')||'rgba(110,128,150,0.055)').trim();
    ctx.lineWidth = 0.5;
    for(var x=0;x<=W;x+=passo){ ctx.strokeStyle=(x%(passo*5)===0)?forte:fraca; ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
    for(var y=0;y<=H;y+=passo){ ctx.strokeStyle=(y%(passo*5)===0)?forte:fraca; ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }
  }
  desenhar();
  window.addEventListener('resize', desenhar);
  window._redesenharFundo = desenhar;
})();

/* ---- Tema ---- */
var iconeTemaEl = document.getElementById('iconeTema');
iconeTemaEl.innerHTML = svgIcone('sol');
document.getElementById('btnTema').addEventListener('click', function(){
  var raiz = document.documentElement;
  var claro = raiz.getAttribute('data-tema') === 'claro';
  if(claro){ raiz.removeAttribute('data-tema'); iconeTemaEl.innerHTML = svgIcone('sol'); }
  else { raiz.setAttribute('data-tema','claro'); iconeTemaEl.innerHTML = svgIcone('lua'); }
  if(window._redesenharFundo) setTimeout(window._redesenharFundo, 60);
});

/* ---- Token / sessão ---- */
function pegarToken(){
  try { return localStorage.getItem('token') || sessionStorage.getItem('token'); } catch(e){ return null; }
}
function sair(){
  try { localStorage.removeItem('token'); sessionStorage.removeItem('token'); } catch(e){}
  window.location.href = 'login.html';
}
document.getElementById('btnSair').addEventListener('click', sair);
document.getElementById('logoLink').addEventListener('click', function(e){ e.preventDefault(); window.scrollTo({top:0,behavior:'smooth'}); });

var TOKEN = pegarToken();
if(!TOKEN){ window.location.href = 'login.html'; }

function api(url, opcoes){
  opcoes = opcoes || {};
  opcoes.headers = Object.assign({ 'Authorization': 'Bearer ' + TOKEN }, opcoes.headers || {});
  return fetch(url, opcoes).then(function(resp){
    if(resp.status === 401 || resp.status === 403){
      // 401 = token inválido; 403 = não é Diretor. Nos dois casos, tira do painel.
      return resp.json().then(function(d){
        throw { tipo: 'acesso', status: resp.status, erro: (d && d.erro) || 'Acesso negado.' };
      });
    }
    return resp.json().then(function(d){ return { status: resp.status, dados: d }; });
  });
}

/* ---- Toast ---- */
var toastEl = document.getElementById('toast');
var toastTimer = null;
function toast(msg, tipo){
  toastEl.className = 'toast ver ' + (tipo || 'ok');
  toastEl.querySelector('.toast-ico').innerHTML = svgIcone(tipo === 'erro' ? 'alert-circle' : 'check');
  toastEl.querySelector('.toast-txt').textContent = msg;
  aplicarIcones(toastEl);
  if(toastTimer) clearTimeout(toastTimer);
  toastTimer = setTimeout(function(){ toastEl.className = 'toast'; }, 3200);
}

/* ==================== TELA 1: NUVENZINHAS ==================== */
var telaClientes = document.getElementById('telaClientes');
var telaTrabalhos = document.getElementById('telaTrabalhos');
var nuvensEl = document.getElementById('nuvens');
var buscaEl = document.getElementById('buscaCliente');
var TODOS_CLIENTES = [];

function iconHtml(nome){ return '<i class="ti ti-'+nome+'"></i>'; }

function renderNuvens(lista){
  if(!lista.length){
    nuvensEl.innerHTML = '<div class="estado-vazio">'+svgIcone('inbox')+'<div>Nenhum cliente encontrado.</div></div>';
    return;
  }
  nuvensEl.innerHTML = lista.map(function(c){
    return '<button class="nuvem" data-id="'+c.id+'" data-nome="'+encodeURIComponent(c.nome)+'">'
      + '<span class="nuvem-ico">'+svgIcone('building')+'</span>'
      + '<span>'+c.nome+'</span>'
      + '</button>';
  }).join('');
  nuvensEl.querySelectorAll('.nuvem').forEach(function(btn){
    btn.addEventListener('click', function(){
      abrirCliente(btn.getAttribute('data-id'), decodeURIComponent(btn.getAttribute('data-nome')));
    });
  });
}

function carregarClientes(){
  nuvensEl.innerHTML = '<div class="carregando-linha">'+iconHtml('loader-2')+' Carregando clientes...</div>';
  aplicarIcones(nuvensEl);
  api('/api/clientes').then(function(res){
    if(!res.dados.sucesso) throw { erro: res.dados.erro || 'Falha ao listar clientes.' };
    TODOS_CLIENTES = res.dados.clientes || [];
    renderNuvens(TODOS_CLIENTES);
  }).catch(function(e){
    if(e.tipo === 'acesso'){ sair(); return; }
    nuvensEl.innerHTML = '<div class="estado-vazio">'+svgIcone('alert-circle')+'<div>'+(e.erro||'Erro ao carregar.')+'</div></div>';
  });
}

buscaEl.addEventListener('input', function(){
  var termo = buscaEl.value.trim().toLowerCase();
  var filtrados = TODOS_CLIENTES.filter(function(c){ return c.nome.toLowerCase().indexOf(termo) !== -1; });
  renderNuvens(filtrados);
});

/* ==================== TELA 2: TRABALHOS DO CLIENTE ==================== */
var listaTrabEl   = document.getElementById('trabalhosLista');
var tituloClienteEl = document.getElementById('tituloCliente');
var buscaTrabEl   = document.getElementById('buscaTrab');
var chipsFiltroEl = document.getElementById('chipsFiltro');
var CLIENTE_ATUAL = null;
var TRABALHOS = [];          // tudo que veio do cliente
var FILTRO_ATUAL = 'aguardando'; // padrão: só os que precisam de aprovação
var BUSCA_ATUAL = '';

// Ícone de PDF verde, pequeno e uniforme (mesmo tamanho pra todos).
function pdfVerde(){
  return '<span class="pdf-mini">'
    + '<svg viewBox="0 0 38 44" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">'
    +   '<path d="M4 2h20l10 10v28a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z" fill="#1f8a55"/>'
    +   '<path d="M24 2l10 10H26a2 2 0 0 1-2-2V2z" fill="#166b41"/>'
    + '</svg>'
    + '<span class="pdf-tag">PDF</span>'
    + '</span>';
}

function estadoDoTrab(trab){
  if(trab.pdf) return 'aprovado';
  if(trab.relatorio_em_andamento) return 'aguardando';
  return 'sem';
}

function selo(trab){
  var e = estadoDoTrab(trab);
  if(e === 'aprovado')   return '<span class="selo selo-verde">Aprovado</span>';
  if(e === 'aguardando') return '<span class="selo selo-amarelo">Aguardando aprovação</span>';
  return '<span class="selo selo-cinza">'+(trab.status_rotulo || 'Em processo')+'</span>';
}

function acoesDoTrab(trab){
  var e = estadoDoTrab(trab);
  if(e === 'aprovado'){
    return '<button class="btn-acao btn-refazer" data-valor="Refazer">'+svgIcone('refresh')+' Refazer</button>';
  }
  if(e === 'aguardando'){
    return '<button class="btn-acao btn-aprovar"   data-valor="Aprovado">'+svgIcone('check')+' Aprovar</button>'
         + '<button class="btn-acao btn-refazer"   data-valor="Refazer">'+svgIcone('refresh')+' Refazer</button>'
         + '<button class="btn-acao btn-andamento" data-valor="Em Andamento">'+svgIcone('progress')+' Em Andamento</button>';
  }
  return '<span class="aviso-sem-rel">'+svgIcone('clock')+' Sem relatório ainda</span>';
}

function cardTrabalho(trab){
  var amostraTxt = trab.amostra || '—';
  if(trab.amostra_extra) amostraTxt += ' <span style="color:var(--txt-4)">+'+trab.amostra_extra+'</span>';
  return '<div class="card-trab" data-id="'+trab.id+'">'
    + pdfVerde()
    + '<div class="card-trab-info">'
    +   '<div class="card-trab-titulo">'+amostraTxt+' '+selo(trab)+'</div>'
    +   '<div class="card-trab-amostra">'+(trab.ensaio || 'Ensaio')+'</div>'    
    +   '<div class="card-trab-id">'+(trab.id_trabalho || '')+'</div>'
    + '</div>'
    + '<div class="card-trab-acoes">'+acoesDoTrab(trab)+'</div>'
    + '</div>';
}

function ligarAcoesCard(cardEl){
  cardEl.querySelectorAll('.btn-acao').forEach(function(btn){
    btn.addEventListener('click', function(){
      aprovar(cardEl.getAttribute('data-id'), btn.getAttribute('data-valor'), cardEl);
    });
  });
}

// Aplica filtro (chip) + busca (texto) sobre TRABALHOS e re-renderiza.
function contarPorEstado(){
  var c = { todos: TRABALHOS.length, aguardando: 0, aprovado: 0 };
  TRABALHOS.forEach(function(t){
    var e = estadoDoTrab(t);
    if(e === 'aguardando') c.aguardando++;
    else if(e === 'aprovado') c.aprovado++;
  });
  return c;
}

function renderChips(){
  var c = contarPorEstado();
  var defs = [
    { id:'aguardando', rot:'Aguardando aprovação', n:c.aguardando },
    { id:'todos',      rot:'Todos',                 n:c.todos },
    { id:'aprovado',   rot:'Aprovados',             n:c.aprovado }
  ];
  chipsFiltroEl.innerHTML = defs.map(function(d){
    return '<button class="chip-filtro'+(FILTRO_ATUAL===d.id?' ativo':'')+'" data-filtro="'+d.id+'">'
      + d.rot + ' <span class="cont">'+d.n+'</span></button>';
  }).join('');
  chipsFiltroEl.querySelectorAll('.chip-filtro').forEach(function(chip){
    chip.addEventListener('click', function(){
      FILTRO_ATUAL = chip.getAttribute('data-filtro');
      renderChips();
      renderTrabalhos();
    });
  });
}

function renderTrabalhos(){
  var termo = BUSCA_ATUAL.trim().toLowerCase();
  var lista = TRABALHOS.filter(function(t){
    // filtro por estado
    if(FILTRO_ATUAL !== 'todos' && estadoDoTrab(t) !== FILTRO_ATUAL) return false;
    // busca por texto (amostra, ensaio, id)
    if(termo){
      var alvo = ((t.amostra||'')+' '+(t.ensaio||'')+' '+(t.id_trabalho||'')).toLowerCase();
      if(alvo.indexOf(termo) === -1) return false;
    }
    return true;
  });

  if(!lista.length){
    var msg = FILTRO_ATUAL === 'aguardando'
      ? 'Nenhum relatório aguardando aprovação para este cliente.'
      : 'Nenhum trabalho encontrado com esse filtro.';
    listaTrabEl.innerHTML = '<div class="estado-vazio">'+svgIcone('inbox')+'<div>'+msg+'</div></div>';
    return;
  }
  listaTrabEl.innerHTML = lista.map(cardTrabalho).join('');
  aplicarIcones(listaTrabEl);
  listaTrabEl.querySelectorAll('.card-trab').forEach(ligarAcoesCard);
}

buscaTrabEl.addEventListener('input', function(){
  BUSCA_ATUAL = buscaTrabEl.value;
  renderTrabalhos();
});

function abrirCliente(recordId, nome){
  CLIENTE_ATUAL = { id: recordId, nome: nome };
  tituloClienteEl.textContent = nome;
  telaClientes.style.display = 'none';
  telaTrabalhos.style.display = 'block';
  FILTRO_ATUAL = 'aguardando'; BUSCA_ATUAL = ''; buscaTrabEl.value = '';
  window.scrollTo({ top: 0 });
  listaTrabEl.innerHTML = '<div class="carregando-linha"><i class="ti ti-loader-2"></i> Carregando trabalhos...</div>';
  chipsFiltroEl.innerHTML = '';
  aplicarIcones(listaTrabEl);

  api('/api/cliente/'+encodeURIComponent(recordId)+'/trabalhos?modo=recente').then(function(res){
    if(!res.dados.sucesso) throw { erro: res.dados.erro || 'Falha ao carregar trabalhos.' };
    TRABALHOS = res.dados.trabalhos || [];
    renderChips();
    renderTrabalhos();
  }).catch(function(e){
    if(e.tipo === 'acesso'){ sair(); return; }
    listaTrabEl.innerHTML = '<div class="estado-vazio">'+svgIcone('alert-circle')+'<div>'+(e.erro||'Erro ao carregar.')+'</div></div>';
  });
}

function voltarParaClientes(){
  telaTrabalhos.style.display = 'none';
  telaClientes.style.display = 'block';
  window.scrollTo({ top: 0 });
}
document.getElementById('btnVoltar').addEventListener('click', voltarParaClientes);

/* ---- Ação de aprovação (PATCH) ---- */
function aprovar(recordIdTrabalho, valor, cardEl){
  cardEl.classList.add('processando');
  api('/api/trabalho/'+encodeURIComponent(recordIdTrabalho)+'/aprovacao', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ valor: valor })
  }).then(function(res){
    cardEl.classList.remove('processando');
    if(!res.dados.sucesso) throw { erro: res.dados.erro || 'Falha ao aplicar.' };

    // Atualiza o objeto em memória pra refletir o novo estado (e recontar chips).
    var id = cardEl.getAttribute('data-id');
    var t = TRABALHOS.filter(function(x){ return x.id === id; })[0];
    if(t){
      if(valor === 'Aprovado'){ t.pdf = true; t.relatorio_em_andamento = false; }
      else if(valor === 'Refazer'){ t.pdf = false; t.relatorio_em_andamento = true; }
      else { t.pdf = false; t.relatorio_em_andamento = true; }
    }
    renderChips();

    var msg = valor === 'Aprovado' ? 'Relatório aprovado! O cliente já poderá visualizar.'
            : valor === 'Refazer'  ? 'Marcado para refazer.'
            : 'Marcado como em andamento.';
    toast(msg, 'ok');

    // Se o card não pertence mais ao filtro atual (ex: aprovou estando em
    // "aguardando"), some da lista; senão, re-renderiza os botões.
    if(FILTRO_ATUAL !== 'todos' && t && estadoDoTrab(t) !== FILTRO_ATUAL){
      renderTrabalhos();
    } else {
      var seloEl = cardEl.querySelector('.selo');
      if(seloEl && t){ seloEl.outerHTML = selo(t); }
      var acoesEl = cardEl.querySelector('.card-trab-acoes');
      if(acoesEl && t){ acoesEl.innerHTML = acoesDoTrab(t); aplicarIcones(acoesEl); ligarAcoesCard(cardEl); }
    }
  }).catch(function(e){
    cardEl.classList.remove('processando');
    if(e.tipo === 'acesso'){ sair(); return; }
    toast(e.erro || 'Não foi possível aplicar a ação.', 'erro');
  });
}

/* ---- Início ---- */
aplicarIcones();
carregarClientes();

</script>
</body>
</html>
</file>


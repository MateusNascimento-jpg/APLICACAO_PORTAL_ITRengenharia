/* Redirecionamento pós-login por perfil (decisão da seção 14/pendência 6 do
   documento: Cliente -> portal.html, Diretor -> painel.html). O painel.html
   ainda não existe (é a última peça do roadmap); por enquanto, qualquer
   perfil que não seja Cliente também cai no portal, para não travar o
   acesso a quem loga antes do painel estar pronto. */
function destinoPorPerfil(perfil){
  if(perfil === 'Diretor') return 'painel.html';
  return 'portal.html';
}

formLogin.addEventListener('submit', function(e){
  e.preventDefault();
  esconderAlertaForm();

  var documento = limparDocumento(campoDocumento.value);
  var senha = campoSenha.value;

  var docInvalido = (documento.length !== 11 && documento.length !== 14);
  var senhaInvalida = senha.length === 0;
  mostrarErroCampo(grupoDocumento, erroDocumento, docInvalido);
  mostrarErroCampo(grupoSenha, erroSenha, senhaInvalida);
  if(docInvalido || senhaInvalida) return;

  setCarregando(true);

  fetch('/login', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ documento: documento, senha: senha })
  })
  .then(function(resp){ return resp.json().then(function(dados){ return { status: resp.status, dados: dados }; }); })
  .then(function(res){
    setCarregando(false);
    if(!res.dados || !res.dados.sucesso){
      mostrarAlertaForm((res.dados && res.dados.erro) || 'Documento ou senha inválidos.');
      return;
    }
    try {
      if(document.getElementById('lembrar').checked){
        localStorage.setItem('token', res.dados.token);
      } else {
        sessionStorage.setItem('token', res.dados.token);
        localStorage.setItem('token', res.dados.token); // portal.html hoje só lê de localStorage
      }
    } catch(err){}
    var perfil = res.dados.usuario && res.dados.usuario.perfil;
    window.location.href = destinoPorPerfil(perfil);
  })
  .catch(function(){
    setCarregando(false);
    mostrarAlertaForm('Não foi possível conectar ao servidor. Verifique sua internet e tente novamente.');
  });
});

/* Limpa erro do campo assim que a pessoa volta a digitar */
campoDocumento.addEventListener('input', function(){ mostrarErroCampo(grupoDocumento, erroDocumento, false); esconderAlertaForm(); });
campoSenha.addEventListener('input', function(){ mostrarErroCampo(grupoSenha, erroSenha, false); esconderAlertaForm(); });

/* Link "Esqueci minha senha": tela ainda não existe (fica para depois,
